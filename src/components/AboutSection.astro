---

<section class="px-6 sm:px-10 lg:px-16 pb-14 max-w-5xl mx-auto">
  <div class="grid sm:grid-cols-2 gap-10 lg:gap-16">

    <div>
      <p class="text-base leading-relaxed mb-4" style="color:var(--text-em);">
        I'm an embedded software engineer with a focus on broadband gateways, router firmware,
        and network protocol stacks. Most of my work lives in C, Bash, and Linux userspace —
        on platforms like RDK-B and OpenWRT.
      </p>
      <p class="text-base leading-relaxed" style="color:var(--text-muted);">
        This site is a personal hub, not a portfolio. For work samples visit
        <a href="https://portfolio.coveyjorjet.com" target="_blank" rel="noopener" style="color:var(--accent);">
          portfolio.coveyjorjet.com
        </a>.
      </p>
    </div>

    <div>
      <h2 class="text-xs terminal-font tracking-widest uppercase mb-5" style="color:var(--text-muted);">
        now
      </h2>
      <ul class="space-y-3">
        {[
          { label: 'working on', value: 'OneWiFi integration onto WiFi 8 RDKB device' },
          { label: 'learning',   value: 'Rust, Captive-Portal, Yocto Project' },
          { label: 'reading',    value: "The Rust Book" },
          { label: 'status',     value: 'open to interesting problems' },
        ].map(({ label, value }) => (
          <li class="flex gap-3 sm:gap-4 text-sm sm:text-base">
            <span
              class="terminal-font flex-shrink-0 w-20 sm:w-24 pt-0.5 text-xs"
              style="color:var(--text-muted);letter-spacing:0.02em;"
            >{label}</span>
            <span style="color:var(--text-em);">{value}</span>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>
