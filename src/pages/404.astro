---
// src/pages/404.astro
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="404 — coveyjorjet"
  description="Page not found."
>
  <Nav />
  <main class="pt-32 pb-16 px-5 sm:px-8 max-w-4xl mx-auto">
    <div class="terminal-window" style="max-width: 480px;">
      <div class="terminal-titlebar">
        <span class="terminal-dot terminal-dot-red"></span>
        <span class="terminal-dot terminal-dot-yellow"></span>
        <span class="terminal-dot terminal-dot-green"></span>
        <span class="terminal-font ml-3 text-xs" style="color:var(--text);opacity:0.5;">bash — 404</span>
      </div>
      <div class="terminal-body terminal-font text-term-base">
        <div class="flex gap-2">
          <span class="term-prompt">~$</span>
          <span class="term-strong">cd this-page</span>
        </div>
        <div class="mt-1 term-red">bash: cd: this-page: No such file or directory</div>
        <div class="mt-3 term-muted">the route you requested does not exist.</div>
        <div class="mt-4">
          <a href="/" class="term-accent underline">← back to ~</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
